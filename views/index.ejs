<%- include('partials/header') %>

    <!-- HERO SECTION -->
    <section class="hero"
        style="padding: 140px 5% 100px; text-align: center; position: relative; overflow: hidden; background: radial-gradient(circle at 80% 0%, rgba(99, 102, 241, 0.15), transparent 40%), radial-gradient(circle at 20% 100%, rgba(236, 72, 153, 0.1), transparent 40%);">
        <div
            style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; opacity: 0.4; z-index: 0;">
            <div
                style="position: absolute; top: -10%; left: 30%; width: 500px; height: 500px; background: var(--primary); filter: blur(160px); border-radius: 50%; animation: pulse 10s infinite alternate;">
            </div>
        </div>

        <div style="position: relative; z-index: 1; max-width: 1000px; margin: 0 auto;">
            <div data-aos="fade-up"
                style="display: inline-flex; align-items: center; gap: 8px; background: rgba(99, 102, 241, 0.08); color: var(--primary-light); padding: 8px 16px; border-radius: 100px; font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px; border: 1px solid rgba(99, 102, 241, 0.2); margin-bottom: 30px;">
                <span
                    style="width: 6px; height: 6px; background: var(--primary); border-radius: 50%; display: inline-block;"></span>
                Premium Creative Hub
            </div>
            <h1
                style="font-family: var(--font-heading); font-size: clamp(3rem, 9vw, 5.5rem); font-weight: 800; line-height: 1.05; margin-bottom: 24px; letter-spacing: -3px; color: #fff;">
                Think deeper, <br>
                <span
                    style="background: linear-gradient(135deg, #fff, var(--primary-light)); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;">write
                    bolder.</span>
            </h1>
            <p
                style="font-size: 1.25rem; color: var(--text-muted); max-width: 650px; margin: 0 auto 48px; line-height: 1.6; font-weight: 400;">
                A curated space where high-level insights meet exceptional digital experiences. Discover the future of
                narrative.
            </p>
            <div style="display: flex; gap: 1.5rem; justify-content: center; flex-wrap: wrap;">
                <a href="/create" class="btn"
                    style="text-decoration: none; padding: 1rem 2.5rem; font-size: 1.05rem;">Start Your Journey</a>
                <a href="#blogs"
                    style="text-decoration: none; color: var(--text); padding: 1rem 2.5rem; border: 1px solid var(--border); border-radius: 100px; font-weight: 600; transition: 0.3s; background: rgba(255, 255, 255, 0.03); font-size: 1.05rem; backdrop-filter: blur(10px);">Explore
                    Feed</a>
            </div>
        </div>
    </section>

    <style>
        @keyframes pulse {
            0% {
                transform: scale(1);
                opacity: 0.3;
            }

            100% {
                transform: scale(1.2);
                opacity: 0.5;
            }
        }
    </style>


    <!-- BLOG FEED -->
    <div id="blogs" style="padding: 80px 5%;">
        <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 50px;">
            <div>
                <h2 style="font-size: 2rem; font-weight: 700;">Latest Stories</h2>
                <div
                    style="width: 60px; height: 4px; background: linear-gradient(90deg, var(--primary), var(--secondary)); border-radius: 2px; margin-top: 10px;">
                </div>
            </div>
            <% if(user) { %>
                <a href="/create"
                    style="color: var(--primary); text-decoration: none; font-weight: 600; font-size: 0.9rem; display: flex; align-items: center; gap: 8px;">
                    <i class="fa-solid fa-plus"></i> NEW STORY
                </a>
                <% } %>
        </div>

        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); gap: 30px;">
            <% if (posts && posts.length> 0) { %>
                <% posts.forEach(function(post) { %>
                    <article class="blog-card"
                        style="background: var(--card-bg); border-radius: 32px; border: 1px solid var(--border); overflow: hidden; transition: 0.5s cubic-bezier(0.2, 0.8, 0.2, 1); position: relative; height: 100%; display: flex; flex-direction: column; backdrop-filter: blur(12px);">
                        <a href="/post/<%= post.id %>"
                            style="display: block; position: relative; height: 260px; overflow: hidden; margin: 12px; border-radius: 24px;">
                            <img src="<%= post.imageUrl || 'https://images.unsplash.com/photo-1499750310107-5fef28a66643?q=80&w=1000' %>"
                                alt="<%= post.title %>"
                                style="width: 100%; height: 100%; object-fit: cover; transition: 0.8s cubic-bezier(0.2, 0.8, 0.2, 1);">
                            <div
                                style="position: absolute; top: 15px; left: 15px; background: rgba(0,0,0,0.4); backdrop-filter: blur(12px); padding: 6px 14px; border-radius: 100px; font-size: 0.7rem; font-weight: 700; color: #fff; border: 1px solid rgba(255,255,255,0.1); text-transform: uppercase; letter-spacing: 0.5px;">
                                <%= (post.category || 'Opinion' ) %>
                            </div>
                        </a>

                        <div style="padding: 20px 32px 32px; flex-grow: 1; display: flex; flex-direction: column;">
                            <h3
                                style="font-family: var(--font-heading); font-size: 1.5rem; font-weight: 700; margin-bottom: 12px; line-height: 1.3; letter-spacing: -0.5px;">
                                <a href="/post/<%= post.id %>"
                                    style="color: var(--text); text-decoration: none; transition: 0.3s;">
                                    <%= post.title %>
                                </a>
                            </h3>

                            <p
                                style="font-size: 0.95rem; color: var(--text-muted); line-height: 1.6; margin-bottom: 25px; display: -webkit-box; -webkit-line-clamp: 3; line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                                <%= (post.content || "" ).replace(/<[^>]*>/g, '') %>
                            </p>


                            <div
                                style="margin-top: auto; display: flex; align-items: center; justify-content: space-between; padding-top: 24px;">
                                <div style="display: flex; align-items: center; gap: 12px;">
                                    <div
                                        style="width: 40px; height: 40px; border-radius: 12px; background: linear-gradient(135deg, var(--primary), var(--secondary)); display: flex; align-items: center; justify-content: center; color: #fff; font-weight: 700; font-size: 0.9rem;">
                                        <%= (post.author && post.author.name) ? post.author.name.charAt(0).toUpperCase()
                                            : 'A' %>
                                    </div>
                                    <div>
                                        <p
                                            style="font-size: 0.9rem; font-weight: 600; color: var(--text); margin-bottom: 2px;">
                                            <%= (post.author && post.author.name) ? post.author.name : 'Anonymous' %>
                                        </p>
                                        <p style="font-size: 0.75rem; color: var(--text-muted); font-weight: 500;">
                                            <%= post.createdAt ? post.createdAt.toLocaleDateString('en-US', {
                                                month: 'short' , day: 'numeric' }) : '' %> • 5 min read
                                        </p>
                                    </div>
                                </div>

                                <% if (user && post.author && post.author._id.toString()===user._id.toString()) { %>
                                    <div style="display: flex; gap: 8px;">
                                        <a href="/post/edit/<%= post.id %>"
                                            style="width: 36px; height: 36px; border-radius: 10px; background: rgba(255,255,255,0.05); display: flex; align-items: center; justify-content: center; color: var(--text-muted); transition: 0.3s;"><i
                                                class="fa-regular fa-pen-to-square"></i></a>
                                        <a href="/post/delete/<%= post.id %>" onclick="return confirm('Are you sure?')"
                                            style="width: 36px; height: 36px; border-radius: 10px; background: rgba(239, 68, 68, 0.1); display: flex; align-items: center; justify-content: center; color: #ef4444; transition: 0.3s;"><i
                                                class="fa-regular fa-trash-can"></i></a>
                                    </div>
                                    <% } %>
                            </div>
                        </div>
                    </article>
                    <style>
                        .blog-card:hover {
                            transform: translateY(-10px);
                            border-color: rgba(99, 102, 241, 0.3);
                            box-shadow: 0 30px 60px -12px rgba(0, 0, 0, 0.6);
                        }

                        .blog-card:hover img {
                            transform: scale(1.1);
                        }

                        .blog-card h3 a:hover {
                            color: var(--primary-light);
                        }
                    </style>

                    <% }); %>
                        <% } else { %>
                            <div
                                style="grid-column: 1 / -1; text-align: center; padding: 100px 20px; background: var(--card-bg); border-radius: 24px; border: 1px dashed var(--border);">
                                <i class="fa-regular fa-folder-open"
                                    style="font-size: 3rem; color: var(--text-muted); margin-bottom: 20px; display: block;"></i>
                                <h3 style="font-size: 1.5rem; margin-bottom: 10px;">No stories found yet</h3>
                                <p style="color: var(--text-muted); margin-bottom: 30px;">Be the one to spark the
                                    conversation.</p>
                                <a href="/create" class="btn" style="text-decoration: none;">Write First Story</a>
                            </div>
                            <% } %>
        </div>
    </div>

    <!-- ABOUT SECTION -->
    <section id="about" style="padding: 100px 5%; background: rgba(255, 255, 255, 0.02);">
        <div
            style="max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center;">
            <div>
                <span
                    style="color: var(--primary); font-weight: 700; letter-spacing: 2px; text-transform: uppercase; font-size: 0.8rem;">Our
                    Story</span>
                <h2 style="font-size: 2.5rem; font-weight: 800; margin: 20px 0 30px;">A space for <br><span
                        style="color: var(--primary);">meaningful</span> dialogue.</h2>
                <p style="color: var(--text-muted); font-size: 1.1rem; line-height: 1.8; margin-bottom: 20px;">
                    LUXBLOG was founded on the belief that words have the power to change the world. We provide a clean,
                    distraction-free environment for writers to express their most impactful ideas.
                </p>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px; margin-top: 40px;">
                    <div>
                        <h4 style="font-size: 2rem; color: var(--text); font-weight: 800;">10k+</h4>
                        <p style="color: var(--text-muted); font-size: 0.9rem;">Passionate Writers</p>
                    </div>
                    <div>
                        <h4 style="font-size: 2rem; color: var(--text); font-weight: 800;">50k+</h4>
                        <p style="color: var(--text-muted); font-size: 0.9rem;">Deep Stories</p>
                    </div>
                </div>
            </div>
            <div style="position: relative;">
                <div
                    style="width: 100%; height: 500px; border-radius: 30px; overflow: hidden; transform: rotate(2deg);">
                    <img src="https://images.unsplash.com/photo-1499750310107-5fef28a66643?q=80&w=1000" alt="About"
                        style="width: 100%; height: 100%; object-fit: cover;">
                </div>
                <div
                    style="position: absolute; -bottom: 30px; -left: 30px; background: var(--primary); padding: 30px; border-radius: 20px; box-shadow: 0 20px 40px rgba(0,0,0,0.3); transform: rotate(-3deg);">
                    <i class="fa-solid fa-quote-left" style="font-size: 2rem; margin-bottom: 15px; display: block;"></i>
                    <p style="font-weight: 600; font-size: 1.1rem;">"Quality over quantity, always."</p>
                </div>
            </div>
        </div>
    </section>

    <%- include('partials/footer') %>